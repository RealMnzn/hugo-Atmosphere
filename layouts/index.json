{{- $pages := where .Site.RegularPages "Section" "posts" -}}
[{{ range $i, $p := $pages }}{{ if $i }},{{ end }}
  {"title":{{ $p.Title | jsonify }},"url":{{ $p.RelPermalink | jsonify }},"date":"{{ $p.Date.Format "2006-01-02" }}","tags":{{ $p.Params.tags | jsonify }},"content":{{ $p.Plain | truncate 300 | jsonify }}}
{{- end }}]
